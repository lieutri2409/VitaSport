@using Shopping.Models.ViewModels
@model List<UserRoleViewModel>

<style>

	.stat-card {
		border-radius: 16px;
		transition: 0.3s;
		border: none;
	}

		.stat-card:hover {
			transform: translateY(-6px);
			box-shadow: 0 12px 25px rgba(0,0,0,0.1);
		}

	.table-container {
		border-radius: 16px;
		overflow: hidden;
		background: white;
	}

	.role-badge {
		padding: 6px 14px;
		border-radius: 20px;
		font-size: 13px;
		font-weight: 600;
	}

	.role-admin {
		background: #dc2626;
		color: white;
	}

	.role-staff {
		background: #16a34a;
		color: white;
	}

	.role-customer {
		background: #e5e7eb;
		color: #111;
	}

</style>

<div class="container mt-5">

	<div class="d-flex justify-content-between align-items-center mb-4">

		<h2 class="fw-bold text-dark text-uppercase">
			<i class="fas fa-users text-primary me-2"></i>Quản lý người dùng
		</h2>

	</div>

	<div class="row g-3 mb-4">

		<div class="col-md-3">
			<div class="card stat-card bg-primary text-white p-3 shadow-sm">

				<div class="d-flex align-items-center">

					<div class="fs-2 me-3">
						<i class="fas fa-user"></i>
					</div>

					<div>
						<h6 class="small text-uppercase opacity-75">Tổng User</h6>
						<h3 class="fw-bold mb-0">@Model.Count</h3>
					</div>

				</div>

			</div>
		</div>

		<div class="col-md-3">
			<div class="card stat-card bg-danger text-white p-3 shadow-sm">

				<div class="d-flex align-items-center">

					<div class="fs-2 me-3">
						<i class="fas fa-user-shield"></i>
					</div>

					<div>
						<h6 class="small text-uppercase opacity-75">Admin</h6>
						<h3 class="fw-bold mb-0">@Model.Count(u => u.Role == "Admin")</h3>
					</div>

				</div>

			</div>
		</div>

		<div class="col-md-3">
			<div class="card stat-card bg-success text-white p-3 shadow-sm">

				<div class="d-flex align-items-center">

					<div class="fs-2 me-3">
						<i class="fas fa-user-tie"></i>
					</div>

					<div>
						<h6 class="small text-uppercase opacity-75">Nhân viên</h6>
						<h3 class="fw-bold mb-0">@Model.Count(u => u.Role == "NhanVien")</h3>
					</div>

				</div>

			</div>
		</div>

		<div class="col-md-3">
			<div class="card stat-card bg-secondary text-white p-3 shadow-sm">

				<div class="d-flex align-items-center">

					<div class="fs-2 me-3">
						<i class="fas fa-user"></i>
					</div>

					<div>
						<h6 class="small text-uppercase opacity-75">Khách hàng</h6>
						<h3 class="fw-bold mb-0">@Model.Count(u => u.Role == "KhachHang")</h3>
					</div>

				</div>

			</div>
		</div>

	</div>

	<div class="card shadow-sm border-0 table-container">

		<div class="card-header bg-light fw-bold">
			<i class="fas fa-list me-2"></i>Danh sách người dùng
		</div>

		<div class="table-responsive">

			<table class="table table-hover align-middle mb-0">

				<thead class="bg-light">
					<tr class="text-muted small text-uppercase">
						<th>Email</th>
						<th>Role</th>
						<th>Sửa Role</th>
						<th class="text-end">Xóa</th>
					</tr>
				</thead>

				<tbody>

					@foreach (var user in Model)
					{

						<tr>

							<td>
								<strong>@user.Email</strong>
							</td>

							<td>

								@if (user.Role == "Admin")
								{
									<span class="role-badge role-admin">Admin</span>
								}
								else if (user.Role == "NhanVien")
								{

									<span class="role-badge role-staff">Nhân viên</span>
								}
								else
								{

									<span class="role-badge role-customer">Khách hàng</span>
								}

							</td>

							<td>

								<button class="btn btn-sm btn-outline-warning"
										onclick="showEdit('@user.UserId')">
									<i class="fas fa-edit"></i> Sửa
								</button>

								<form asp-action="UpdateRole"
									  method="post"
									  id="edit-@user.UserId"
									  style="display:none">

									<input type="hidden"
										   name="userId"
										   value="@user.UserId" />

									<select name="role"
											class="form-select mt-2">

										<option value="Admin">Admin</option>
										<option value="NhanVien">Nhân viên</option>
										<option value="KhachHang">Khách hàng</option>

									</select>

									<button class="btn btn-success btn-sm mt-2">
										Lưu
									</button>

									<button type="button"
											class="btn btn-secondary btn-sm mt-2"
											onclick="hideEdit('@user.UserId')">
										Hủy
									</button>

								</form>

							</td>

							<td class="text-end">

								<a class="btn btn-sm btn-outline-danger"
								   asp-action="DeleteUser"
								   asp-route-userId="@user.UserId">

									<i class="fas fa-trash"></i>

								</a>

							</td>

						</tr>

					}

				</tbody>

			</table>

		</div>

	</div>

</div>

<script>

	function showEdit(id){
	document.getElementById("edit-"+id).style.display="block";
	}

	function hideEdit(id){
	document.getElementById("edit-"+id).style.display="none";
	}

</script>
