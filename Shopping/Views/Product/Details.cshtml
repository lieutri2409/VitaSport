@model Shopping.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container mt-4 pb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="ListPublic">Sản phẩm</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="card shadow-lg border-0 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-5">
                <img src="@Model.ImageUrl" class="img-fluid h-100 w-100" style="min-height: 450px; object-fit: cover;" alt="@Model.Name">
            </div>

            <div class="col-md-7">
                <div class="card-body p-5">
                    <h6 class="text-primary text-uppercase fw-bold mb-2">@Model.Category?.CategoryName</h6>

                    <h2 class="card-title display-5 fw-bold mb-3">@Model.Name</h2>

                    <p class="card-text text-danger fs-2 fw-bold mb-4">
                        @String.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:N0} VNĐ", Model.Price)
                    </p>

                    <hr class="my-4 opacity-10">

                    <h5 class="fw-bold">Mô tả chi tiết:</h5>
                    <p class="text-muted mb-4" style="line-height: 1.8;">@Model.Description</p>

                    <div class="mb-4">
                        @if (Model.Quantity > 0)
                        {
                            <span class="badge bg-success-subtle text-success border border-success px-3 py-2 rounded-pill">
                                <i class="fas fa-check-circle me-1"></i> Còn hàng (@Model.Quantity sản phẩm)
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-danger border border-danger px-3 py-2 rounded-pill">
                                <i class="fas fa-times-circle me-1"></i> Tạm hết hàng
                            </span>
                        }
                    </div>

                    <!-- 🔥 FIX CHỖ NÀY -->
                    <div class="d-flex gap-3 mt-5">

                        @if (Model.Quantity > 0)
                        {
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <a asp-controller="Cart"
                                   asp-action="AddToCart"
                                   asp-route-id="@Model.Id"
                                   class="btn btn-primary btn-lg px-5 py-3 shadow-sm fw-bold">
                                    <i class="fas fa-cart-plus me-2"></i>THÊM VÀO GIỎ HÀNG
                                </a>
                            }
                            else
                            {
                                <button type="button"
                                        class="btn btn-primary btn-lg px-5 py-3 shadow-sm fw-bold"
                                        data-bs-toggle="modal"
                                        data-bs-target="#loginRequiredModal">
                                    <i class="fas fa-cart-plus me-2"></i>THÊM VÀO GIỎ HÀNG
                                </button>
                            }
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-lg px-5 py-3 fw-bold" disabled>
                                HẾT HÀNG
                            </button>
                        }

                        <a asp-action="ListPublic" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                        </a>
                    </div>

                    <!-- END FIX -->

                    <div class="mt-5 row g-3">
                        <div class="col-6 col-md-4">
                            <small class="text-muted"><i class="fas fa-truck me-2"></i>Giao hàng 2h</small>
                        </div>
                        <div class="col-6 col-md-4">
                            <small class="text-muted"><i class="fas fa-undo me-2"></i>Đổi trả 7 ngày</small>
                        </div>
                        <div class="col-6 col-md-4">
                            <small class="text-muted"><i class="fas fa-shield-alt me-2"></i>Bảo hành 12 tháng</small>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>