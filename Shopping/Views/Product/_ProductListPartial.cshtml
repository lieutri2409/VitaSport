@model IEnumerable<Shopping.Models.Product>
@using System.Globalization

@{
    int currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"] : 1;
    int totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
}

@if (Model == null || !Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-box-open fa-4x text-secondary opacity-50 mb-4"></i>
        <h3 class="fw-bold mb-2">Không tìm thấy sản phẩm</h3>
        <p class="text-muted mb-0">Hãy thử thay đổi bộ lọc.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                <div class="product-card">

                    <div class="product-image-wrap">
                        @if (item.Quantity == 0)
                        {
                            <span class="top-badge-left stock-badge">Hết hàng</span>
                        }

                        <span class="top-badge-right">
                            @(item.Category?.CategoryName ?? "Sản phẩm")
                        </span>

                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/products/no-image.png" : item.ImageUrl)" />
                    </div>

                    <div class="product-body">
                        <div class="product-name mb-2">@item.Name</div>

                        <div class="price-text mb-2">
                            @String.Format(new CultureInfo("vi-VN"), "{0:N0} đ", item.Price)
                        </div>

                        <div class="meta-row">
                            Còn lại: <strong>@item.Quantity</strong>
                        </div>
                    </div>

                    <div class="product-footer d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn btn-outline-secondary flex-fill rounded-soft">
                            Xem
                        </a>

                        @if (item.Quantity > 0)
                        {
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <a asp-controller="Cart"
                                   asp-action="AddToCart"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary flex-fill rounded-soft">
                                    Mua
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-primary flex-fill"
                                        data-bs-toggle="modal"
                                        data-bs-target="#loginRequiredModal">
                                    Mua
                                </button>
                            }
                        }
                        else
                        {
                            <button class="btn btn-secondary flex-fill" disabled>
                                Hết hàng
                            </button>
                        }
                    </div>

                </div>
            </div>
        }
    </div>

    <!-- PAGINATION -->
    <div class="pagination-wrap text-center mt-4">
        @for (int i = 1; i <= totalPages; i++)
        {
            <a href="#"
               class="ajax-page-link btn btn-sm @(i == currentPage ? "btn-primary" : "btn-outline-primary")"
               data-page="@i">
                @i
            </a>
        }
    </div>
}