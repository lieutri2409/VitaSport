@model Shopping.Models.Product

@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<style>
    .form-shell {
        max-width: 900px;
        margin: 0 auto;
    }

    .form-card {
        border: none;
        border-radius: 28px;
        overflow: hidden;
        background: rgba(255,255,255,0.92);
        box-shadow: 0 20px 60px rgba(15,23,42,0.10);
        backdrop-filter: blur(10px);
    }

    .form-header {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        padding: 28px;
    }

        .form-header h3 {
            font-weight: 800;
            margin: 0;
        }

    .section-title {
        font-size: 14px;
        font-weight: 800;
        color: #475569;
        letter-spacing: 1px;
        margin-bottom: 16px;
        text-transform: uppercase;
    }

    .soft-input,
    .soft-select,
    .soft-textarea {
        border-radius: 16px !important;
        border: 1.5px solid #dbe2ea !important;
        background: #f8fafc !important;
        padding-left: 14px !important;
        min-height: 56px;
    }

    .soft-textarea {
        min-height: 140px !important;
        padding-top: 16px !important;
    }

        .soft-input:focus,
        .soft-select:focus,
        .soft-textarea:focus {
            border-color: #2563eb !important;
            box-shadow: 0 0 0 0.2rem rgba(37,99,235,0.12) !important;
            background: #fff !important;
        }

    .image-upload-box {
        border: 2px dashed #bfdbfe;
        background: linear-gradient(180deg, #f8fbff, #f1f5f9);
        border-radius: 22px;
        padding: 28px;
    }

    .preview-box {
        border-radius: 20px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        overflow: hidden;
        min-height: 260px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .preview-box img {
            width: 100%;
            height: 260px;
            object-fit: cover;
            display: none;
        }

    .preview-placeholder {
        text-align: center;
        color: #64748b;
        padding: 20px;
    }

    .action-btn {
        border-radius: 16px;
        font-weight: 700;
        min-height: 54px;
    }
</style>

<div class="container py-4 py-lg-5">
    <div class="form-shell">
        <div class="form-card">
            <div class="form-header">
                <h3><i class="fas fa-box-open me-2"></i>Thêm sản phẩm mới</h3>
                <div class="mt-2 opacity-75">Nhập thông tin sản phẩm và tải ảnh từ máy tính</div>
            </div>

            <div class="p-4 p-lg-5">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4"></div>

                    <div class="row g-4">
                        <div class="col-lg-7">
                            <div class="section-title">Thông tin sản phẩm</div>

                            <div class="mb-3">
                                <label asp-for="Name" class="form-label fw-semibold">Tên sản phẩm</label>
                                <input asp-for="Name" class="form-control soft-input" placeholder="Nhập tên sản phẩm" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Price" class="form-label fw-semibold">Giá bán</label>
                                    <input asp-for="Price" type="number" class="form-control soft-input" placeholder="Nhập giá bán" />
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Quantity" class="form-label fw-semibold">Số lượng</label>
                                    <input asp-for="Quantity" type="number" class="form-control soft-input" placeholder="Nhập số lượng" />
                                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mt-3">
                                <label asp-for="CategoryId" class="form-label fw-semibold">Danh mục</label>
                                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select soft-select">
                                    <option value="">-- Chọn danh mục --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <div class="mt-3">
                                <label asp-for="Description" class="form-label fw-semibold">Mô tả sản phẩm</label>
                                <textarea asp-for="Description" class="form-control soft-textarea" placeholder="Nhập mô tả chi tiết sản phẩm"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-lg-5">
                            <div class="section-title">Hình ảnh sản phẩm</div>

                            <div class="image-upload-box">
                                <label asp-for="ImageFile" class="form-label fw-semibold">Chọn ảnh từ máy</label>
                                <input asp-for="ImageFile" type="file" class="form-control soft-input" accept="image/*" id="imageInputCreate" />
                                <span asp-validation-for="ImageFile" class="text-danger small"></span>

                                <div class="preview-box mt-3">
                                    <img id="previewCreate" alt="Ảnh xem trước" />
                                    <div class="preview-placeholder" id="placeholderCreate">
                                        <i class="fas fa-image fa-3x mb-3 text-primary"></i>
                                        <div class="fw-bold">Chưa có ảnh nào được chọn</div>
                                        <small>Ảnh xem trước sẽ hiển thị tại đây</small>
                                    </div>
                                </div>

                                <div class="mt-3 text-muted small">
                                    Hỗ trợ file ảnh như JPG, PNG, WEBP.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-4">
                        <div class="col-md-8">
                            <button type="submit" class="btn btn-primary w-100 action-btn shadow">
                                <i class="fas fa-check-circle me-2"></i>Lưu sản phẩm
                            </button>
                        </div>
                        <div class="col-md-4">
                            <a asp-action="Manage" class="btn btn-outline-secondary w-100 action-btn">
                                Hủy bỏ
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const imageInputCreate = document.getElementById('imageInputCreate');
        const previewCreate = document.getElementById('previewCreate');
        const placeholderCreate = document.getElementById('placeholderCreate');

        imageInputCreate?.addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (!file) {
                previewCreate.style.display = 'none';
                previewCreate.src = '';
                placeholderCreate.style.display = 'block';
                return;
            }

            const reader = new FileReader();
            reader.onload = function (event) {
                previewCreate.src = event.target.result;
                previewCreate.style.display = 'block';
                placeholderCreate.style.display = 'none';
            };
            reader.readAsDataURL(file);
        });
    </script>
}