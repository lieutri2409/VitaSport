@model IEnumerable<Shopping.Models.Product>
@using System.Globalization

@{
	ViewData["Title"] = "Quản lý sản phẩm";

	var totalQuantity = Model?.Sum(p => p.Quantity) ?? 0;
	var outOfStockCount = Model?.Count(p => p.Quantity <= 0) ?? 0;
	var lowStockCount = Model?.Count(p => p.Quantity > 0 && p.Quantity <= 5) ?? 0;
}

<style>

	.stat-card {
		border-radius: 16px;
		transition: 0.3s;
		border: none;
	}

		.stat-card:hover {
			transform: translateY(-6px);
			box-shadow: 0 12px 25px rgba(0,0,0,0.1);
		}

	.product-img {
		width: 60px;
		height: 60px;
		object-fit: cover;
		border-radius: 12px;
	}

	.table-container {
		border-radius: 16px;
		overflow: hidden;
		background: white;
	}

	.badge-stock {
		padding: 6px 12px;
		border-radius: 8px;
		font-weight: 600;
		min-width: 80px;
		display: inline-block;
	}

	.row-out-of-stock {
		background: #fff5f5 !important;
	}

</style>

<div class="container mt-5 pb-5">

	<div class="d-flex justify-content-between align-items-center mb-4">

		<h2 class="fw-bold text-dark text-uppercase">
			<i class="fas fa-warehouse text-primary me-2"></i>Quản lý kho sản phẩm
		</h2>

		@if (User.IsInRole("Admin"))
		{
			<a asp-action="Create"
			   class="btn btn-primary px-4 py-2 fw-bold shadow-sm rounded-pill"> <i class="fas fa-plus-circle me-2"></i>Nhập hàng </a>
		}

	</div>

	<div class="row g-3 mb-4">

		<div class="col-md-4">

			<div class="card stat-card bg-primary text-white p-3 shadow-sm">

				<div class="d-flex align-items-center">

					<div class="fs-2 me-3">
						<i class="fas fa-box"></i>
					</div>

					<div>
						<h6 class="small text-uppercase opacity-75">Tổng số lượng trong kho</h6>
						<h3 class="fw-bold mb-0">@totalQuantity</h3>
					</div>

				</div>

			</div>

		</div>

		<div class="col-md-4">

			<div class="card stat-card bg-warning text-dark p-3 shadow-sm">

				<div class="d-flex align-items-center">

					<div class="fs-2 me-3">
						<i class="fas fa-exclamation-triangle"></i>
					</div>

					<div>
						<h6 class="small text-uppercase opacity-75">Sắp hết (≤5)</h6>
						<h3 class="fw-bold mb-0">@lowStockCount</h3>
					</div>

				</div>

			</div>

		</div>

		<div class="col-md-4">

			<div class="card stat-card bg-danger text-white p-3 shadow-sm">

				<div class="d-flex align-items-center">

					<div class="fs-2 me-3">
						<i class="fas fa-times-circle"></i>
					</div>

					<div>
						<h6 class="small text-uppercase opacity-75">Hết hàng</h6>
						<h3 class="fw-bold mb-0">@outOfStockCount</h3>
					</div>

				</div>

			</div>

		</div>

	</div>

	<div class="card border-0 shadow-sm table-container">

		<div class="table-responsive">

			<table class="table table-hover align-middle mb-0">

				<thead class="bg-light">

					<tr class="text-muted small text-uppercase">

						<th class="ps-4">Thông tin sản phẩm</th>
						<th>Giá</th>
						<th class="text-center">Số lượng</th>
						<th>Trạng thái</th>
						<th class="text-end pe-4">Thao tác</th>

					</tr>

				</thead>

				<tbody>

					@foreach (var item in Model)
					{

						var isOutOfStock = item.Quantity <= 0;
						var isLowStock = item.Quantity > 0 && item.Quantity <= 5;

						<tr class="@(isOutOfStock ? "row-out-of-stock" : "")">

							<td class="ps-4">

								<div class="d-flex align-items-center">

									<img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://placehold.co/60x60" : item.ImageUrl)"
										 class="product-img shadow-sm me-3">

									<div>

										<div class="fw-bold @(isOutOfStock ? "text-danger" : "text-dark")">
											@item.Name
										</div>

										<small class="text-muted">
											Danh mục: @item.Category?.CategoryName
										</small>

									</div>

								</div>

							</td>

							<td>

								<span class="fw-bold text-primary">

									@item.Price.ToString("N0", new CultureInfo("vi-VN")) đ

								</span>

							</td>

							<td class="text-center">

								<span class="badge badge-stock
	@(isOutOfStock ? "bg-danger" :
				 isLowStock ? "bg-warning text-dark" :
				 "bg-success")">

								@item.Quantity

								</span>

							</td>

							<td>

							@if (isOutOfStock)
								{

									<span class="text-danger fw-bold small">
										<i class="fas fa-times-circle"></i> Hết hàng
									</span>

								}
								else if (isLowStock)
								{

									<span class="text-warning fw-bold small">
										<i class="fas fa-exclamation-triangle"></i> Sắp hết
									</span>

								}
								else
								{

									<span class="text-success fw-bold small">
										<i class="fas fa-check-circle"></i> Còn hàng
									</span>

								}

							</td>

							<td class="text-end pe-4">

								@if (User.IsInRole("Admin"))
								{

									<div class="btn-group shadow-sm">

										<a asp-action="Edit"
										   asp-route-id="@item.Id"
										   class="btn btn-sm btn-outline-primary">

											<i class="fas fa-edit"></i>

										</a>

										<a asp-action="Delete"
										   asp-route-id="@item.Id"
										   class="btn btn-sm btn-outline-danger">

											<i class="fas fa-trash"></i>

										</a>

									</div>

								}
								else
								{

									<span class="text-muted small">Chỉ xem</span>

								}

							</td>

						</tr>

					}

				</tbody>

			</table>

		</div>

	</div>

</div>
