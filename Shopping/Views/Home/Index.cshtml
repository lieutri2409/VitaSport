@model IEnumerable<Shopping.Models.Product>
@using System.Linq
@using System.Globalization

@{
    ViewData["Title"] = "Trang chủ";

    var products = Model?.ToList() ?? new List<Shopping.Models.Product>();
    var groupedProducts = products
        .Select((value, index) => new { value, index })
        .GroupBy(x => x.index / 4)
        .Select(g => g.Select(x => x.value).ToList())
        .ToList();
}

<style>
    .hero-wrap {
        padding: 24px 0 8px;
    }

    .hero-box {
        background: radial-gradient(circle at top right, rgba(96,165,250,.28), transparent 30%), linear-gradient(135deg, #0f172a 0%, #1e293b 48%, #2563eb 100%);
        border-radius: 34px;
        overflow: hidden;
        position: relative;
        color: white;
        box-shadow: 0 30px 70px rgba(15,23,42,0.18);
    }

    .hero-content {
        padding: 72px 52px;
    }

    .hero-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.14);
        color: #fff;
        padding: 9px 16px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 14px;
        margin-bottom: 22px;
        backdrop-filter: blur(8px);
    }

    .hero-title {
        font-size: 3.2rem;
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -1.2px;
        margin-bottom: 18px;
    }

    .hero-desc {
        color: rgba(255,255,255,0.82);
        font-size: 1.08rem;
        max-width: 560px;
        margin-bottom: 28px;
    }

    .hero-metric {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 22px;
        padding: 18px;
        backdrop-filter: blur(10px);
        text-align: center;
    }

    .hero-image-wrap {
        padding: 38px 38px 38px 0;
    }

    .hero-image {
        width: 100%;
        min-height: 430px;
        max-height: 470px;
        object-fit: cover;
        border-radius: 28px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.24);
    }

    .section-head {
        margin-bottom: 24px;
    }

    .section-title {
        font-weight: 800;
        letter-spacing: -0.6px;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .section-subtitle {
        color: #64748b;
        margin-bottom: 0;
    }

    .feature-card,
    .promo-card,
    .product-card {
        background: rgba(255,255,255,0.86);
        border: 1px solid rgba(226,232,240,0.9);
        border-radius: 26px;
        box-shadow: 0 14px 36px rgba(15,23,42,0.06);
        backdrop-filter: blur(10px);
    }

    .feature-card {
        padding: 28px;
        height: 100%;
        transition: .28s;
    }

        .feature-card:hover,
        .product-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 22px 48px rgba(15,23,42,0.10);
        }

    .feature-icon {
        width: 66px;
        height: 66px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #dbeafe, #eff6ff);
        color: #2563eb;
        font-size: 24px;
        margin-bottom: 18px;
    }

    .featured-slider-wrap {
        position: relative;
        padding: 0 34px;
    }

    .slider-btn {
        width: 54px;
        height: 54px;
        border: none;
        border-radius: 50%;
        background: rgba(255,255,255,0.95);
        box-shadow: 0 12px 28px rgba(15,23,42,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        transition: 0.25s;
        color: #0f172a;
    }

        .slider-btn:hover {
            background: #2563eb;
            color: white;
        }

        .slider-btn.prev-btn {
            left: -4px;
        }

        .slider-btn.next-btn {
            right: -4px;
        }

    .product-card {
        overflow: hidden;
        transition: .28s;
        height: 100%;
    }

    .product-thumb {
        height: 230px;
        background: linear-gradient(180deg, #f8fafc, #eef2ff);
        overflow: hidden;
        position: relative;
    }

        .product-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .35s;
        }

    .product-card:hover .product-thumb img {
        transform: scale(1.06);
    }

    .product-badge {
        position: absolute;
        top: 14px;
        right: 14px;
        background: rgba(255,255,255,0.94);
        color: #2563eb;
        font-size: 12px;
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 999px;
        box-shadow: 0 10px 20px rgba(15,23,42,0.08);
        z-index: 2;
    }

    .out-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        background: #ef4444;
        color: white;
        font-size: 12px;
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 999px;
        z-index: 2;
    }

    .quick-action {
        position: absolute;
        left: 14px;
        right: 14px;
        bottom: -60px;
        transition: .3s;
    }

    .product-card:hover .quick-action {
        bottom: 14px;
    }

    .price-text {
        font-size: 1.28rem;
        font-weight: 800;
        color: #ef4444;
    }

    .stock-text {
        font-size: 12px;
        color: #64748b;
    }

    .product-name {
        min-height: 46px;
        line-height: 1.4;
    }

    .promo-card {
        padding: 42px;
        background: radial-gradient(circle at right top, rgba(37,99,235,.25), transparent 25%), linear-gradient(135deg, #111827, #0f172a);
        color: white;
        overflow: hidden;
        position: relative;
    }

        .promo-card p {
            color: rgba(255,255,255,.78);
        }

    .empty-box {
        border: 2px dashed #cbd5e1;
        border-radius: 26px;
        padding: 60px 20px;
        background: rgba(255,255,255,0.68);
        text-align: center;
    }

    .soft-btn {
        border-radius: 16px;
        font-weight: 700;
    }

    @@media (max-width: 991px) {
        .hero-content {
            padding: 42px 28px;
        }

        .hero-title {
            font-size: 2.25rem;
        }

        .hero-image-wrap {
            padding: 0 28px 28px;
        }

        .featured-slider-wrap {
            padding: 0 10px;
        }

        .slider-btn {
            width: 44px;
            height: 44px;
        }

            .slider-btn.prev-btn {
                left: -10px;
            }

            .slider-btn.next-btn {
                right: -10px;
            }
    }

    @@media (max-width: 767px) {
        .hero-title {
            font-size: 1.9rem;
        }

        .slider-btn {
            display: none;
        }
    }
</style>

<section class="hero-wrap">
    <div class="container">
        <div class="hero-box">
            <div class="row align-items-center g-0">
                <div class="col-lg-7">
                    <div class="hero-content">
                        <div class="hero-chip">
                            <i class="fas fa-bolt text-warning"></i>
                            Chuyên trang mua sắm công nghệ
                        </div>

                        <h1 class="hero-title">
                            Mua sắm hiện đại, thiết kế đẹp, trải nghiệm mượt mà
                        </h1>

                        <p class="hero-desc">
                            Khám phá những sản phẩm nổi bật với giao diện chuyên nghiệp, giá tốt và trải nghiệm mua hàng trực quan tại VitaSport
                        </p>

                        <div class="d-flex flex-wrap gap-3 mb-4">
                            <a asp-controller="Product" asp-action="ListPublic" class="btn btn-primary btn-lg px-4 py-3 rounded-4 fw-bold shadow">
                                Mua ngay
                            </a>
                            <a href="#featured-products" class="btn btn-light btn-lg px-4 py-3 rounded-4 fw-bold text-dark">
                                Xem sản phẩm nổi bật
                            </a>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-4">
                                <div class="hero-metric">
                                    <h4 class="fw-bold mb-1">1000+</h4>
                                    <small class="text-white-50">Sản phẩm</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="hero-metric">
                                    <h4 class="fw-bold mb-1">24/7</h4>
                                    <small class="text-white-50">Hỗ trợ</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="hero-metric">
                                    <h4 class="fw-bold mb-1">2H</h4>
                                    <small class="text-white-50">Giao nhanh</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="hero-image-wrap">
                        <img class="hero-image"
                             src="/images/products/no-image.png"
                             alt="Hero banner"
                             onerror="this.onerror=null; this.src='https://placehold.co/900x700?text=VitaSport';">
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="text-center section-head">
            <h2 class="section-title">VitaSport – Nâng tầm trải nghiệm thể thao của bạn</h2>
            <p class="section-subtitle">Trang bị thể thao chính hãng, giá tốt, giao nhanh toàn quốc</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-shipping-fast"></i>
                    </div>
                    <h4 class="fw-bold">Giao hàng siêu tốc</h4>
                    <p class="text-muted mb-0">
                        Giao hàng nhanh toàn quốc
                        Đảm bảo nhận hàng đúng hẹn, đóng gói an toàn.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h4 class="fw-bold">Bảo hành uy tín</h4>
                    <p class="text-muted mb-0">
                        Cam kết chính hãng
                        Sản phẩm rõ nguồn gốc, đổi trả minh bạch.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h4 class="fw-bold">Hỗ trợ tận tâm</h4>
                    <p class="text-muted mb-0">
                        Hỗ trợ 24/7
                        Luôn sẵn sàng tư vấn và giải đáp cho bạn.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="featured-products" class="py-5">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-end section-head gap-3">
            <div>
                <h2 class="section-title mb-1">Sản phẩm nổi bật</h2>
                <p class="section-subtitle">Khám phá các sản phẩm nổi bật của chúng tôi</p>
            </div>

            <a asp-controller="Product" asp-action="ListPublic" class="btn btn-outline-primary soft-btn px-4">
                Xem tất cả
            </a>
        </div>

        @if (products.Any())
        {
            <div class="featured-slider-wrap">
                @if (groupedProducts.Count > 1)
                {
                    <button class="slider-btn prev-btn" type="button" data-bs-target="#featuredProductCarousel" data-bs-slide="prev">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                }

                <div id="featuredProductCarousel" class="carousel slide" data-bs-ride="false">
                    <div class="carousel-inner">
                        @for (int i = 0; i < groupedProducts.Count; i++)
                        {
                            var group = groupedProducts[i];
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <div class="row g-4">
                                    @foreach (var item in group)
                                    {
                                        <div class="col-12 col-sm-6 col-lg-3">
                                            <div class="product-card">
                                                <div class="product-thumb">
                                                    @if (item.Quantity == 0)
                                                    {
                                                        <span class="out-badge">Hết hàng</span>
                                                    }

                                                    <span class="product-badge">
                                                        @(item.Category?.CategoryName ?? "Sản phẩm")
                                                    </span>

                                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/products/no-image.png" : item.ImageUrl)"
                                                         alt="@item.Name"
                                                         onerror="this.onerror=null; this.src='/images/products/no-image.png';" />

                                                    <div class="quick-action">
                                                        @if (item.Quantity > 0)
                                                        {
                                                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                                                            {
                                                                <a asp-controller="Cart"
                                                                   asp-action="AddToCart"
                                                                   asp-route-id="@item.Id"
                                                                   class="btn btn-primary flex-fill rounded-soft">
                                                                    Mua
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <button type="button"
                                                                        class="btn btn-primary flex-fill rounded-soft"
                                                                        data-bs-toggle="modal"
                                                                        data-bs-target="#loginRequiredModal">
                                                                    Mua
                                                                </button>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <button class="btn btn-secondary flex-fill rounded-soft" disabled>
                                                                Hết hàng
                                                            </button>
                                                        }
                                                    </div>
                                                </div>

                                                <div class="p-3 p-lg-4">
                                                    <div class="stock-text mb-2">
                                                        <i class="fas fa-box me-1"></i>Kho: @item.Quantity
                                                    </div>

                                                    <h6 class="fw-bold product-name mb-3" title="@item.Name">
                                                        @item.Name
                                                    </h6>

                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div class="price-text">
                                                            @String.Format(new CultureInfo("vi-VN"), "{0:N0} đ", item.Price)
                                                        </div>

                                                        <a asp-controller="Product"
                                                           asp-action="Details"
                                                           asp-route-id="@item.Id"
                                                           class="btn btn-light border rounded-circle"
                                                           title="Xem chi tiết">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (groupedProducts.Count > 1)
                {
                    <button class="slider-btn next-btn" type="button" data-bs-target="#featuredProductCarousel" data-bs-slide="next">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                }
            </div>
        }
        else
        {
            <div class="empty-box">
                <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                <h5 class="fw-bold">Chưa có sản phẩm nào</h5>
                <p class="text-muted mb-0">Hiện tại kho hàng chưa có sản phẩm để hiển thị.</p>
            </div>
        }
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="promo-card">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold mb-3">
                        Ưu đãi nổi bật
                    </span>
                    <h2 class="fw-bold display-6 mb-3">
                        Flash Sale tuần này
                    </h2>
                    <p class="lead mb-4">
                        Săn deal phụ kiện, tai nghe và thiết bị gaming với mức giá hấp dẫn trong thời gian ngắn.
                    </p>
                    <a asp-controller="Product" asp-action="ListPublic" class="btn btn-warning btn-lg rounded-pill px-4 fw-bold">
                        Săn deal ngay
                    </a>
                </div>

                <div class="col-lg-5 text-end d-none d-lg-block">
                    <i class="fas fa-bolt text-warning" style="font-size: 150px; opacity: 0.18;"></i>
                </div>
            </div>
        </div>
    </div>
</section>