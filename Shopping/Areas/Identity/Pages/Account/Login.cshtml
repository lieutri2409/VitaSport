@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    .login-wrapper {
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0f172a, #1e293b);
        padding: 40px 15px;
    }

    .login-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        padding: 40px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.25);
    }

    .login-title {
        font-weight: 700;
        color: #1e293b;
    }

    .form-control {
        border-radius: 10px;
        padding: 12px;
    }

    .btn-login {
        background: #2563eb;
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-login:hover {
        background: #1d4ed8;
    }

    .login-footer a {
        text-decoration: none;
        font-size: 14px;
        color: #2563eb;
    }

    .login-footer a:hover {
        text-decoration: underline;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">

        <div class="text-center mb-4">
            <h3 class="login-title">Đăng nhập tài khoản</h3>
            <p class="text-muted small">Chào mừng bạn quay lại VitaSport</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" placeholder="admin@gmail.com" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe">
                    Ghi nhớ đăng nhập
                </label>
            </div>

            <button type="submit" class="btn btn-login w-100 text-white">
                Đăng nhập
            </button>

            <div class="text-center mt-4 login-footer">
                
                <p>
                    Chưa có tài khoản?
                    <a asp-page="./Register">Đăng ký ngay</a>
                </p>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}