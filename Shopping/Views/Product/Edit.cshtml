@model Shopping.Models.Product

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<style>
    .form-shell {
        max-width: 950px;
        margin: 0 auto;
    }

    .form-card {
        border: none;
        border-radius: 28px;
        overflow: hidden;
        background: rgba(255,255,255,0.94);
        box-shadow: 0 20px 60px rgba(15,23,42,0.10);
    }

    .form-header {
        background: linear-gradient(135deg, #0f172a, #2563eb);
        color: white;
        padding: 28px;
    }

        .form-header h3 {
            font-weight: 800;
            margin: 0;
        }

    .section-title {
        font-size: 14px;
        font-weight: 800;
        color: #475569;
        letter-spacing: 1px;
        margin-bottom: 16px;
        text-transform: uppercase;
    }

    .soft-input,
    .soft-select,
    .soft-textarea {
        border-radius: 16px !important;
        border: 1.5px solid #dbe2ea !important;
        background: #f8fafc !important;
        min-height: 56px;
    }

    .soft-textarea {
        min-height: 140px !important;
        padding-top: 14px !important;
    }

        .soft-input:focus,
        .soft-select:focus,
        .soft-textarea:focus {
            border-color: #2563eb !important;
            box-shadow: 0 0 0 0.2rem rgba(37,99,235,0.12) !important;
            background: white !important;
        }

    .image-panel {
        border: 1px solid #e2e8f0;
        background: linear-gradient(180deg, #ffffff, #f8fafc);
        border-radius: 24px;
        padding: 24px;
    }

    .current-image-box,
    .new-image-box {
        border-radius: 20px;
        overflow: hidden;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        min-height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .current-image-box img,
        .new-image-box img {
            width: 100%;
            height: 220px;
            object-fit: cover;
        }

        .new-image-box img {
            display: none;
        }

    .empty-preview {
        text-align: center;
        color: #64748b;
        padding: 20px;
    }

    .action-btn {
        border-radius: 16px;
        font-weight: 700;
        min-height: 54px;
    }
</style>

<div class="container py-4 py-lg-5">
    <div class="form-shell">
        <div class="form-card">
            <div class="form-header">
                <h3><i class="fas fa-pen-to-square me-2"></i>Chỉnh sửa sản phẩm</h3>
                <div class="mt-2 opacity-75">Cập nhật thông tin cho sản phẩm: <strong>@Model.Name</strong></div>
            </div>

            <div class="p-4 p-lg-5">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />

                    <div class="row g-4">
                        <div class="col-lg-7">
                            <div class="section-title">Thông tin sản phẩm</div>

                            <div class="mb-3">
                                <label asp-for="Name" class="form-label fw-semibold">Tên sản phẩm</label>
                                <input asp-for="Name" class="form-control soft-input" placeholder="Tên sản phẩm" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Price" class="form-label fw-semibold">Giá bán</label>
                                    <input asp-for="Price" type="number" class="form-control soft-input" placeholder="Giá bán" />
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Quantity" class="form-label fw-semibold">Số lượng</label>
                                    <input asp-for="Quantity" type="number" class="form-control soft-input" placeholder="Số lượng" />
                                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mt-3">
                                <label asp-for="CategoryId" class="form-label fw-semibold">Danh mục</label>
                                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select soft-select">
                                    <option value="">-- Chọn danh mục --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <div class="mt-3">
                                <label asp-for="Description" class="form-label fw-semibold">Mô tả sản phẩm</label>
                                <textarea asp-for="Description" class="form-control soft-textarea" placeholder="Mô tả sản phẩm"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-lg-5">
                            <div class="section-title">Hình ảnh sản phẩm</div>

                            <div class="image-panel">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Ảnh hiện tại</label>
                                    <div class="current-image-box">
                                        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/products/no-image.png" : Model.ImageUrl)"
                                             alt="@Model.Name"
                                             onerror="this.src='/images/products/no-image.png';" />
                                    </div>
                                </div>

                                <div>
                                    <label asp-for="ImageFile" class="form-label fw-semibold">Chọn ảnh mới</label>
                                    <input asp-for="ImageFile" type="file" class="form-control soft-input" accept="image/*" id="imageInputEdit" />
                                    <span asp-validation-for="ImageFile" class="text-danger small"></span>
                                </div>

                                <div class="mt-3">
                                    <label class="form-label fw-semibold">Xem trước ảnh mới</label>
                                    <div class="new-image-box">
                                        <img id="previewEdit" alt="Ảnh mới xem trước" />
                                        <div class="empty-preview" id="placeholderEdit">
                                            <i class="fas fa-cloud-upload-alt fa-3x mb-3 text-primary"></i>
                                            <div class="fw-bold">Chưa chọn ảnh mới</div>
                                            <small>Ảnh mới sẽ hiển thị ở đây sau khi bạn chọn file</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-4">
                        <div class="col-md-8">
                            <button type="submit" class="btn btn-primary w-100 action-btn shadow">
                                <i class="fas fa-save me-2"></i>Lưu thay đổi
                            </button>
                        </div>
                        <div class="col-md-4">
                            <a asp-action="Manage" class="btn btn-outline-secondary w-100 action-btn">
                                Hủy bỏ
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const imageInputEdit = document.getElementById('imageInputEdit');
        const previewEdit = document.getElementById('previewEdit');
        const placeholderEdit = document.getElementById('placeholderEdit');

        imageInputEdit?.addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (!file) {
                previewEdit.style.display = 'none';
                previewEdit.src = '';
                placeholderEdit.style.display = 'block';
                return;
            }

            const reader = new FileReader();
            reader.onload = function (event) {
                previewEdit.src = event.target.result;
                previewEdit.style.display = 'block';
                placeholderEdit.style.display = 'none';
            };
            reader.readAsDataURL(file);
        });
    </script>
}