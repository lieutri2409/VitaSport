@model Shopping.Models.Category

@{
    ViewData["Title"] = "Thêm loại sản phẩm mới";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0 rounded-4">

            <div class="card-header bg-primary text-white text-center py-4">
                <h4 class="mb-0 fw-bold text-uppercase">
                    <i class="fas fa-plus-circle me-2"></i> Tạo loại sản phẩm mới
                </h4>
            </div>

            <div class="card-body p-5">
                <p class="text-muted text-center small mb-4">
                    Vui lòng điền thông tin chính xác vào ô dưới đây
                </p>

                <form asp-action="Create" method="post">
                    <div class="form-floating mb-4">
                        <input asp-for="CategoryName" class="form-control border-2" placeholder="Tên loại sản phẩm" />
                        <label asp-for="CategoryName">
                            <i class="fas fa-folder-plus me-2"></i>Tên loại sản phẩm cần thêm...
                        </label>
                        <span asp-validation-for="CategoryName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-grid gap-3 pt-2">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                            <i class="fas fa-save me-2"></i> LƯU DỮ LIỆU
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary py-2 border-2">
                            <i class="fas fa-arrow-left me-2"></i> Quay lại danh sách
                        </a>
                    </div>
                </form>
            </div>

            <div class="card-footer bg-light text-center py-3 text-muted small">
                Nguyễn Liễu Trí &copy; 2026
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
