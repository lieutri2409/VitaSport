@model List<Shopping.Models.CartItem>

<div class="container mt-5 py-5">
    <h2 class="fw-bold mb-4 text-primary">🛒 Giỏ hàng của bạn</h2>
    @if (Model.Any())
    {
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <table class="table align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Đơn giá</th>
                        <th class="text-center">Số lượng</th>
                        <th>Thành tiền</th>
                        <th class="text-center">Xóa</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@item.ImageUrl" width="60" height="60" class="rounded-3 shadow-sm me-3" style="object-fit: cover;">
                                    <span class="fw-semibold text-dark">@item.Name</span>
                                </div>
                            </td>
                            <td>@item.Price.ToString("N0") đ</td>

                            @* --- PHẦN ĐIỀU CHỈNH SỐ LƯỢNG --- *@
                            <td class="text-center" style="width: 180px;">
                                <div class="input-group input-group-sm justify-content-center">
                                    <a asp-action="Decrease" asp-route-id="@item.ProductId"
                                       class="btn btn-outline-secondary border-end-0 rounded-start-pill px-3">
                                        <i class="fas fa-minus"></i>
                                    </a>
                                    <span class="input-group-text bg-white border-start-0 border-end-0 fw-bold px-3">
                                        @item.Quantity
                                    </span>
                                    <a asp-action="Increase" asp-route-id="@item.ProductId"
                                       class="btn btn-outline-secondary border-start-0 rounded-end-pill px-3">
                                        <i class="fas fa-plus"></i>
                                    </a>
                                </div>
                            </td>

                            <td class="fw-bold text-primary">@item.Total.ToString("N0") đ</td>
                            <td class="text-center">
                                <a asp-action="Remove" asp-route-id="@item.ProductId" class="text-danger fs-5"
                                   onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?')">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="text-end mt-4">
            <h4 class="mb-3">Tổng thanh toán: <span class="text-danger fw-bold fs-2 ms-2">@Model.Sum(x => x.Total).ToString("N0") đ</span></h4>
            <div class="d-flex justify-content-end gap-3">
                <a href="/" class="btn btn-outline-dark px-4 py-2 rounded-pill">Tiếp tục mua sắm</a>
                <a asp-controller="Order" asp-action="Checkout"
                   class="btn btn-primary px-5 py-2 rounded-pill fw-bold shadow">
                    THANH TOÁN NGAY
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 shadow-sm rounded-4 bg-white">
            <i class="fas fa-shopping-basket fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">Giỏ hàng của bạn đang trống!</h4>
            <a href="/" class="btn btn-primary mt-3 px-5 py-2 rounded-pill shadow">Bắt đầu mua sắm ngay</a>
        </div>
    }
</div>