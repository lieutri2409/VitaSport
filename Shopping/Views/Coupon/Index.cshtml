@model IEnumerable<Shopping.Models.Coupon>

@{
    ViewData["Title"] = "Quản lý mã giảm giá";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">🎟 Quản lý mã giảm giá</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-2"></i>Tạo mã mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4">@TempData["Success"]</div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã</th>
                        <th>Tên</th>
                        <th>Loại</th>
                        <th>Giảm</th>
                        <th>Đơn tối thiểu</th>
                        <th>Đã dùng</th>
                        <th>Hạn</th>
                        <th>Trạng thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Code</td>
                            <td>@item.Name</td>
                            <td>@(item.IsPercentage ? "Phần trăm" : "Tiền mặt")</td>
                            <td>
                                @(item.IsPercentage ? $"{item.DiscountValue}%" : $"{item.DiscountValue:N0} đ")
                            </td>
                            <td>@item.MinimumOrderAmount.ToString("N0") đ</td>
                            <td>@item.UsedCount / @item.UsageLimit</td>
                            <td>@item.StartDate.ToString("dd/MM/yyyy") - @item.EndDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Đang bật</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đang tắt</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>

                                <form asp-action="Toggle" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn btn-sm btn-outline-warning">
                                        @(item.IsActive ? "Tắt" : "Bật")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>