@using Microsoft.AspNetCore.Identity
@using Shopping.Models
@using Shopping.Helpers
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VitaSport – Cửa hàng đồ thể thao VN</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --dark: #0f172a;
            --muted: #64748b;
            --light: #f8fafc;
            --card: #ffffff;
            --border: #e2e8f0;
            --warning: #f59e0b;
            --success: #10b981;
            --danger: #ef4444;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(to bottom, #f8fafc, #eef2ff);
            color: #1e293b;
        }

        .navbar {
            background: rgba(255,255,255,0.85) !important;
            backdrop-filter: blur(14px);
            border-bottom: 1px solid rgba(226,232,240,0.8);
            box-shadow: 0 8px 30px rgba(15,23,42,0.05);
        }

        .navbar-brand {
            font-weight: 800;
            letter-spacing: -0.5px;
            color: var(--primary) !important;
            font-size: 1.5rem;
        }

        .brand-badge {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--primary), #60a5fa);
            color: white;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-right: 10px;
            box-shadow: 0 8px 20px rgba(37,99,235,0.25);
        }

        .nav-link {
            color: #475569 !important;
            font-weight: 600;
            position: relative;
            transition: 0.25s;
        }

            .nav-link:hover {
                color: var(--primary) !important;
            }

            .nav-link::after {
                content: "";
                position: absolute;
                left: 12px;
                right: 12px;
                bottom: 4px;
                height: 2px;
                border-radius: 999px;
                background: var(--primary);
                transform: scaleX(0);
                transition: 0.25s;
            }

            .nav-link:hover::after {
                transform: scaleX(1);
            }

        .menu-toggle-btn {
            width: 46px;
            height: 46px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--dark) !important;
            background: white;
            border: 1px solid var(--border);
            box-shadow: 0 8px 20px rgba(15,23,42,0.05);
            transition: 0.25s;
        }

            .menu-toggle-btn:hover {
                color: var(--primary) !important;
                background: #eff6ff;
                border-color: #bfdbfe;
                transform: translateY(-2px);
            }

        .btn-auth {
            border-radius: 12px;
            padding: 9px 16px;
            font-weight: 700;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            box-shadow: 0 10px 24px rgba(37,99,235,0.22);
        }

            .btn-primary:hover {
                transform: translateY(-1px);
            }

        .icon-cart {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: white;
            border: 1px solid var(--border);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 20px rgba(15,23,42,0.05);
            transition: 0.25s;
        }

            .icon-cart:hover {
                background: #eff6ff;
                border-color: #bfdbfe;
                color: var(--primary) !important;
            }

        .offcanvas {
            width: 330px !important;
            border: none !important;
            border-top-right-radius: 24px;
            border-bottom-right-radius: 24px;
            overflow: hidden;
        }

        .offcanvas-header {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            padding: 20px 24px;
        }

        .offcanvas-title {
            font-weight: 800;
        }

        main {
            min-height: 70vh;
        }

        footer {
            background: linear-gradient(135deg, #020617, #0f172a);
            color: #cbd5e1;
            margin-top: 80px;
            position: relative;
            overflow: hidden;
        }

        .footer-glow {
            position: absolute;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: rgba(37,99,235,0.15);
            filter: blur(80px);
            top: -100px;
            right: -100px;
        }

        .footer-title {
            color: white;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .footer-link {
            color: #cbd5e1;
            text-decoration: none;
            transition: 0.25s;
        }

            .footer-link:hover {
                color: white;
            }

        .footer-social a {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.06);
            color: white;
            text-decoration: none;
            transition: 0.25s;
        }

            .footer-social a:hover {
                background: var(--primary);
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg fixed-top py-3">
            <div class="container">

                <a class="menu-toggle-btn text-decoration-none me-2"
                   data-bs-toggle="offcanvas"
                   href="#offcanvasCategory">
                    <i class="fas fa-bars"></i>
                </a>

                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <span class="brand-badge">
                        <i class="fas fa-bolt"></i>
                    </span>
                    VitaSport
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Product" asp-action="ListPublic">Cửa hàng</a>
                        </li>

                        @if (User.IsInRole("Admin") || User.IsInRole("NhanVien"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle px-3" href="#" data-bs-toggle="dropdown">
                                    Hệ thống
                                </a>

                                <ul class="dropdown-menu border-0 shadow rounded-4 p-2">
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2" asp-controller="Category" asp-action="Index">
                                            <i class="fas fa-layer-group me-2 text-primary"></i>Quản lý Loại
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2" asp-controller="Product" asp-action="Manage">
                                            <i class="fas fa-boxes-stacked me-2 text-success"></i>Quản lý Kho
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2"
                                           asp-controller="Coupon" asp-action="Index">
                                            <i class="fas fa-ticket-alt me-2 text-warning"></i>
                                            Quản lý mã giảm giá
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2" asp-controller="Order" asp-action="Manage">
                                            <i class="fas fa-receipt me-2 text-warning"></i>Quản lý đơn hàng
                                        </a>
                                    </li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2" asp-controller="UserRole" asp-action="Index">
                                                <i class="fas fa-users me-2 text-danger"></i>Quản lý người dùng
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">
                        <a asp-controller="Cart" asp-action="Index" class="text-dark position-relative icon-cart">
                            <i class="fas fa-shopping-bag"></i>
                            @{
                                var cart = Context.Session.GetObjectFromJson<List<CartItem>>("UserCart");
                                var count = cart?.Sum(x => x.Quantity) ?? 0;
                            }
                            @if (count > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                      style="font-size:10px;">
                                    @count
                                </span>
                            }
                        </a>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            var currentUser = await UserManager.GetUserAsync(User);
                            var displayName = currentUser?.FullName ?? User.Identity?.Name ?? "User";
                            var firstLetter = displayName.Substring(0, 1).ToUpper();

                            <div class="dropdown">
                                <a class="d-flex align-items-center text-decoration-none dropdown-toggle fw-semibold text-dark"
                                   href="#"
                                   data-bs-toggle="dropdown">
                                    <div class="rounded-circle text-white d-flex justify-content-center align-items-center me-2"
                                         style="width:38px;height:38px;font-size:14px;font-weight:700;background:linear-gradient(135deg,#2563eb,#60a5fa);">
                                        @firstLetter
                                    </div>
                                    <span>@displayName</span>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 rounded-4 p-2">
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2" asp-area="Identity" asp-page="/Account/Manage/Index">
                                            <i class="fas fa-user me-2 text-primary"></i>Tài khoản của tôi
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Address" asp-action="Index">
                                            <i class="fas fa-map-marker-alt me-2 text-danger"></i>
                                            Sổ địa chỉ
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2" asp-controller="Order" asp-action="MyOrder">
                                            <i class="fas fa-box me-2 text-success"></i>Theo dõi đơn hàng
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">
                                            <i class="fas fa-lock me-2 text-warning"></i>Đổi mật khẩu
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger rounded-3 py-2">
                                                <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary btn-auth">
                                Đăng nhập
                            </a>

                            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-auth">
                                Đăng ký
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasCategory">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title">
                <i class="fas fa-list me-2"></i>Danh mục sản phẩm
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0 bg-white">
            @await Component.InvokeAsync("CategoryMenu")
        </div>
    </div>

    <div style="margin-top: 95px;">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="footer-glow"></div>

        <div class="container py-5 position-relative">
            <div class="row g-4 align-items-start">
                <div class="col-lg-5">
                    <h3 class="footer-title mb-3">VitaSport – Cửa hàng đồ thể thao</h3>
                    <p class="mb-3 text-light-emphasis">
                        VitaSport – Cửa hàng đồ thể thao hiện đại với giao diện chuyên nghiệp, sản phẩm chất lượng và trải nghiệm mua sắm mượt mà.
                    </p>
                    <div class="footer-social d-flex gap-2">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-tiktok"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>

                <div class="col-md-3 col-lg-2">
                    <h6 class="text-white fw-bold mb-3">Điều hướng</h6>
                    <div class="d-flex flex-column gap-2">
                        <a class="footer-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        <a class="footer-link" asp-controller="Product" asp-action="ListPublic">Cửa hàng</a>
                        <a class="footer-link" asp-controller="Cart" asp-action="Index">Giỏ hàng</a>
                    </div>
                </div>

                <div class="col-md-4 col-lg-3">
                    <h6 class="text-white fw-bold mb-3">Liên hệ</h6>
                    <div class="d-flex flex-column gap-2">
                        <span><i class="fas fa-phone me-2"></i>0123 456 789</span>
                        <span><i class="fas fa-envelope me-2"></i>VitaSport@gmail.com</span>
                        <span><i class="fas fa-location-dot me-2"></i>Thành phố Hồ Chí Minh, Việt Nam</span>
                    </div>
                </div>

                <div class="col-lg-2">
                    <h6 class="text-white fw-bold mb-3">Hỗ trợ</h6>
                    <div class="d-flex flex-column gap-2">
                        <a href="#" class="footer-link">Chính sách</a>
                        <a href="#" class="footer-link">Bảo hành</a>
                        <a href="#" class="footer-link">Hướng dẫn</a>
                    </div>
                </div>
            </div>

            <hr class="border-secondary my-4" />
            <p class="mb-0 text-center">&copy; 2026 - VitaSport -. All rights reserved.</p>
        </div>
    </footer>

    <!-- Modal yêu cầu đăng nhập -->
    <div class="modal fade" id="loginRequiredModal" tabindex="-1" aria-labelledby="loginRequiredModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="loginRequiredModalLabel">
                        <i class="fas fa-user-lock text-primary me-2"></i>Yêu cầu đăng nhập
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-2">
                    <p class="mb-2 fw-semibold">Bạn cần đăng nhập để thêm sản phẩm vào giỏ hàng và đặt hàng.</p>
                    <p class="text-muted mb-0">Vui lòng đăng nhập hoặc tạo tài khoản để tiếp tục mua sắm tại VitaSport.</p>
                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-3" data-bs-dismiss="modal">
                        Đóng
                    </button>

                    <a asp-area="Identity"
                       asp-page="/Account/Login"
                       class="btn btn-primary rounded-3">
                        Đăng nhập ngay
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["RequireLoginMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var loginModal = new bootstrap.Modal(document.getElementById('loginRequiredModal'));
                loginModal.show();
            });
        </script>
    }

</body>
</html>