@model Shopping.Models.Category
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-header bg-danger text-white text-center py-3">
                <h5 class="mb-0 fw-bold">⚠️ XÁC NHẬN XÓA</h5>
            </div>
            <div class="card-body p-4 text-center">
                <p class="fs-5">Bạn có chắc chắn muốn xóa loại sản phẩm này không?</p>
                <h3 class="text-danger fw-bold mb-4">"@Model.CategoryName"</h3>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="CategoryId" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger fw-bold py-2">XÓA NGAY TỨC THÌ</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">KHÔNG, QUAY LẠI</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>