@model Shopping.Models.ViewModels.CouponViewModel

@{
    ViewData["Title"] = "Mã giảm giá";
}

<div class="container py-4">
    <div class="card shadow-sm border-0 rounded-4 p-4">
        <h3 class="fw-bold text-primary mb-4">🎟 @(Model.Id == 0 ? "Tạo mã giảm giá" : "Cập nhật mã giảm giá")</h3>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            @if (Model.Id != 0)
            {
                <input type="hidden" asp-for="Id" />
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Code" class="form-label fw-semibold">Mã giảm giá</label>
                    <input asp-for="Code" class="form-control" />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Name" class="form-label fw-semibold">Tên mã</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Loại giảm</label>
                    <select asp-for="IsPercentage" class="form-select">
                        <option value="true">Giảm theo %</option>
                        <option value="false">Giảm tiền cố định</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label asp-for="DiscountValue" class="form-label fw-semibold">Giá trị giảm</label>
                    <input asp-for="DiscountValue" class="form-control" />
                    <span asp-validation-for="DiscountValue" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="MaxDiscountAmount" class="form-label fw-semibold">Giảm tối đa</label>
                    <input asp-for="MaxDiscountAmount" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label asp-for="MinimumOrderAmount" class="form-label fw-semibold">Đơn tối thiểu</label>
                    <input asp-for="MinimumOrderAmount" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label asp-for="UsageLimit" class="form-label fw-semibold">Số lượt dùng</label>
                    <input asp-for="UsageLimit" class="form-control" />
                </div>

                <div class="col-md-2">
                    <label asp-for="StartDate" class="form-label fw-semibold">Bắt đầu</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                </div>

                <div class="col-md-2">
                    <label asp-for="EndDate" class="form-label fw-semibold">Kết thúc</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                </div>

                <div class="col-md-12">
                    <div class="form-check mt-2">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Đang bật</label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button class="btn btn-primary px-4 rounded-pill">Lưu</button>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}