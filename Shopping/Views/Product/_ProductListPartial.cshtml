@model IEnumerable<Shopping.Models.Product>
@using System.Globalization

@{
    int? currentCategoryId = ViewData["CurrentCategoryId"] != null ? (int?)ViewData["CurrentCategoryId"] : null;
    int currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"] : 1;
    int totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;

    string keyword = ViewData["Keyword"]?.ToString() ?? "";
    string sortBy = ViewData["SortBy"]?.ToString() ?? "";
    string stockStatus = ViewData["StockStatus"]?.ToString() ?? "";

    decimal? minPrice = ViewData["MinPrice"] as decimal?;
    decimal? maxPrice = ViewData["MaxPrice"] as decimal?;
}

@if (Model == null || !Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-box-open fa-4x text-secondary opacity-50 mb-4"></i>
        <h3 class="fw-bold mb-2">Không tìm thấy sản phẩm</h3>
        <p class="text-muted mb-0">Hãy thử thay đổi bộ lọc để xem thêm sản phẩm khác.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                <div class="product-card">
                    <div class="product-image-wrap">
                        @if (item.Quantity == 0)
                        {
                            <span class="top-badge-left stock-badge">Hết hàng</span>
                        }

                        <span class="top-badge-right">
                            @(item.Category?.CategoryName ?? "Sản phẩm")
                        </span>

                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/products/no-image.png" : item.ImageUrl)"
                             alt="@item.Name"
                             onerror="this.onerror=null; this.src='/images/products/no-image.png';" />
                    </div>

                    <div class="product-body">
                        <div class="product-name mb-2" title="@item.Name">
                            @item.Name
                        </div>

                        <div class="product-desc mb-3">
                            @item.Description
                        </div>

                        <div class="price-text mb-2">
                            @String.Format(new CultureInfo("vi-VN"), "{0:N0} đ", item.Price)
                        </div>

                        <div class="meta-row">
                            <i class="fas fa-cubes me-1"></i>Còn lại: <strong>@item.Quantity</strong> sản phẩm
                        </div>
                    </div>

                    <div class="product-footer">
                        <div class="d-flex gap-2">
                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-secondary flex-fill rounded-soft">
                                <i class="fas fa-eye me-1"></i>Chi tiết
                            </a>

                            @if (item.Quantity > 0)
                            {
                                @if (User.Identity != null && User.Identity.IsAuthenticated)
                                {
                                    <a asp-controller="Cart"
                                       asp-action="AddToCart"
                                       asp-route-id="@item.Id"
                                       class="btn btn-primary flex-fill rounded-soft shadow-sm">
                                        <i class="fas fa-cart-plus me-1"></i>Mua
                                    </a>
                                }
                                else
                                {
                                    <button type="button"
                                            class="btn btn-primary flex-fill rounded-soft shadow-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#loginRequiredModal">
                                        <i class="fas fa-cart-plus me-1"></i>Mua
                                    </button>
                                }
                            }
                            else
                            {
                                <button class="btn btn-secondary flex-fill rounded-soft" disabled>
                                    Hết hàng
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <div class="pagination-wrap d-flex justify-content-center">
            <nav>
                <ul class="pagination custom-pagination">

                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a href="#"
                           class="page-link ajax-page-link"
                           data-page="@(currentPage - 1)">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a href="#"
                               class="page-link ajax-page-link"
                               data-page="@i">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a href="#"
                           class="page-link ajax-page-link"
                           data-page="@(currentPage + 1)">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>

                </ul>
            </nav>
        </div>
    }
}