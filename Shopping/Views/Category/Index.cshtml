@model IEnumerable<Shopping.Models.Category>

@{
	ViewData["Title"] = "Danh mục sản phẩm";
}

<style>

	.stat-card {
		border-radius: 16px;
		transition: 0.3s;
		border: none;
	}

		.stat-card:hover {
			transform: translateY(-6px);
			box-shadow: 0 12px 25px rgba(0,0,0,0.1);
		}

	.table-container {
		border-radius: 16px;
		overflow: hidden;
		background: white;
	}

	.category-icon {
		width: 42px;
		height: 42px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 10px;
		background: #eef2ff;
		color: #2563eb;
	}

	.progress {
		height: 8px;
		border-radius: 10px;
	}

</style>


<div class="container mt-5">

	<div class="d-flex justify-content-between align-items-center mb-4">

		<h2 class="fw-bold text-dark text-uppercase">
			<i class="fas fa-layer-group text-primary me-2"></i>Quản lý danh mục
		</h2>

		@if (User.IsInRole("Admin"))
		{
			<a asp-action="Create" class="btn btn-primary px-4 py-2 fw-bold shadow rounded-pill">
				<i class="fas fa-plus me-2"></i>THÊM LOẠI
			</a>
		}

	</div>


	<div class="row g-3 mb-4">

		<div class="col-md-6">
			<div class="card stat-card bg-primary text-white p-3 shadow-sm">
				<div class="d-flex align-items-center">

					<div class="fs-2 me-3">
						<i class="fas fa-folder"></i>
					</div>

					<div>
						<h6 class="small text-uppercase opacity-75">Tổng loại</h6>
						<h3 class="fw-bold mb-0">@Model.Count()</h3>
					</div>

				</div>
			</div>
		</div>


		<div class="col-md-6">
			<div class="card stat-card bg-success text-white p-3 shadow-sm">
				<div class="d-flex align-items-center">

					<div class="fs-2 me-3">
						<i class="fas fa-box"></i>
					</div>

					<div>
						<h6 class="small text-uppercase opacity-75">Tổng sản phẩm</h6>
						<h3 class="fw-bold mb-0">
							@(Model.Sum(c => c.Products?.Count ?? 0))
						</h3>
					</div>

				</div>
			</div>
		</div>

	</div>


	<div class="card shadow-sm border-0 table-container">

		<div class="table-responsive">

			<table class="table table-hover align-middle mb-0">

				<thead class="bg-light">
					<tr class="text-muted small text-uppercase">
						<th class="ps-4">ID</th>
						<th>Danh mục</th>
						<th class="text-center">Số SP</th>
						<th>Tỷ trọng kho</th>
						<th class="text-end pe-4">Thao tác</th>
					</tr>
				</thead>

				<tbody>

					@if (!Model.Any())
					{
						<tr>
							<td colspan="5" class="text-center py-5 text-muted">
								Chưa có danh mục
							</td>
						</tr>
					}
					else
					{

						var totalProducts = Model.Sum(c => c.Products?.Count ?? 0);

						foreach (var item in Model)
						{
							var count = item.Products?.Count ?? 0;
							var percent = totalProducts > 0 ? (count * 100 / totalProducts) : 0;

							<tr>

								<td class="ps-4 text-muted">#@item.CategoryId</td>

								<td>

									<div class="d-flex align-items-center">

										<div class="category-icon me-3">
											<i class="fas fa-folder-open"></i>
										</div>

										<div>
											<div class="fw-bold">@item.CategoryName</div>
											<small class="text-muted">ID hệ thống: @item.CategoryId</small>
										</div>

									</div>

								</td>

								<td class="text-center">
									<span class="badge bg-info text-dark px-3 py-2 rounded-pill">
										@count SP
									</span>
								</td>

								<td style="min-width:150px">

									<div class="d-flex align-items-center">

										<div class="progress flex-grow-1 me-2">

											<div class="progress-bar
		@(percent > 50 ? "bg-success" : "bg-warning")"
												 style="width:@percent%">
											</div>

										</div>

										<small class="fw-bold text-muted">@percent%</small>

									</div>

								</td>

								<td class="text-end pe-4">

									@if (User.IsInRole("Admin"))
									{
										<div class="btn-group shadow-sm">

											<a asp-action="Edit"
											   asp-route-id="@item.CategoryId"
											   class="btn btn-sm btn-outline-primary">
												<i class="fas fa-edit"></i>
											</a>

											<a asp-action="Delete"
											   asp-route-id="@item.CategoryId"
											   class="btn btn-sm btn-outline-danger">
												<i class="fas fa-trash"></i>
											</a>

										</div>
									}
									else
									{
										<span class="text-muted small">Chỉ xem</span>
									}

								</td>

							</tr>
						}

					}

				</tbody>

			</table>

		</div>

	</div>

</div>