@model Shopping.Models.ViewModels.CheckoutViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Xác nhận đơn hàng";
}

<style>
    .checkout-page {
        padding: 32px 0 48px;
    }

    .checkout-header {
        background: linear-gradient(135deg, #0f172a, #2563eb);
        color: white;
        border-radius: 28px;
        padding: 28px 32px;
        margin-bottom: 28px;
        box-shadow: 0 18px 40px rgba(37,99,235,0.18);
    }

        .checkout-header h2 {
            font-weight: 800;
            margin-bottom: 6px;
        }

    .checkout-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(15,23,42,0.06);
        padding: 24px;
    }

    .address-option {
        border: 1px solid #dbe2ea;
        border-radius: 18px;
        padding: 16px;
        margin-bottom: 12px;
        transition: 0.2s;
        background: #fff;
        cursor: pointer;
    }

        .address-option:hover {
            border-color: #93c5fd;
            background: #f8fbff;
        }

    .default-badge {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 999px;
        background: #eff6ff;
        color: #2563eb;
        font-size: 12px;
        font-weight: 700;
        margin-left: 8px;
    }

    .form-control {
        min-height: 48px;
        border-radius: 14px;
    }

    .summary-box {
        position: sticky;
        top: 100px;
    }

    .product-row {
        border-bottom: 1px solid #edf2f7;
        padding: 14px 0;
    }

    .btn-soft {
        border-radius: 14px;
        font-weight: 700;
    }
</style>

<div class="container checkout-page">
    <div class="checkout-header">
        <h2>Xác nhận đơn hàng</h2>
        <p class="mb-0">Kiểm tra sản phẩm và chọn địa chỉ giao hàng phù hợp.</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4">@TempData["Error"]</div>
    }

    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 mb-3"></div>

    <form asp-action="PlaceOrder" method="post">
        @Html.AntiForgeryToken()

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="checkout-card mb-4">
                    <h4 class="fw-bold mb-3">Địa chỉ giao hàng</h4>

                    @if (Model.SavedAddresses.Any())
                    {
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="radio" asp-for="UseNewAddress" value="false" id="useSavedAddress" />
                            <label class="form-check-label fw-semibold" for="useSavedAddress">
                                Chọn từ sổ địa chỉ
                            </label>
                        </div>

                        @foreach (var addr in Model.SavedAddresses)
                        {
                            <label class="address-option d-block">
                                <div class="form-check">
                                    <input class="form-check-input saved-address-radio"
                                           type="radio"
                                           asp-for="SelectedAddressId"
                                           value="@addr.Id" />

                                    <span class="fw-bold">@addr.FullName</span>
                                    @if (addr.IsDefault)
                                    {
                                        <span class="default-badge">Mặc định</span>
                                    }

                                    <div class="text-muted mt-1">@addr.PhoneNumber</div>
                                    <div class="text-muted">@addr.FullAddress</div>
                                </div>
                            </label>
                        }
                    }

                    <div class="form-check mb-3 mt-3">
                        <input class="form-check-input" type="radio" asp-for="UseNewAddress" value="true" id="useNewAddress" />
                        <label class="form-check-label fw-semibold" for="useNewAddress">
                            Nhập địa chỉ mới
                        </label>
                    </div>

                    <div id="newAddressBox">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Tên người nhận</label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Số điện thoại</label>
                                <input asp-for="PhoneNumber" class="form-control" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">Địa chỉ chi tiết</label>
                                <input asp-for="StreetAddress" class="form-control" />
                                <span asp-validation-for="StreetAddress" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Phường/Xã</label>
                                <input asp-for="Ward" class="form-control" />
                                <span asp-validation-for="Ward" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Quận/Huyện</label>
                                <input asp-for="District" class="form-control" />
                                <span asp-validation-for="District" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Tỉnh/Thành phố</label>
                                <input asp-for="City" class="form-control" />
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="checkout-card">
                    <h4 class="fw-bold mb-3">Sản phẩm trong đơn</h4>

                    @foreach (var item in Model.CartItems)
                    {
                        <div class="product-row d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <img src="@item.ImageUrl"
                                     style="width:70px;height:70px;object-fit:cover;border-radius:12px;"
                                     onerror="this.src='/images/products/no-image.png'" />
                                <div>
                                    <div class="fw-bold">@item.Name</div>
                                    <div class="text-muted">Số lượng: @item.Quantity</div>
                                </div>
                            </div>

                            <div class="fw-bold text-danger">
                                @String.Format(new CultureInfo("vi-VN"), "{0:N0} đ", item.Total)
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="checkout-card summary-box">
                    <h4 class="fw-bold mb-4">Tóm tắt đơn hàng</h4>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mã giảm giá</label>
                        <div class="d-flex gap-2">
                            <input asp-for="CouponCode" class="form-control" placeholder="Nhập mã giảm giá" id="couponCodeInput" />
                            <button type="button" class="btn btn-primary btn-soft" onclick="applyCoupon()">
                                Áp dụng
                            </button>
                        </div>
                        <span asp-validation-for="CouponCode" class="text-danger small"></span>
                        <div id="couponMessage" class="small mt-2"></div>
                    </div>

                    <input type="hidden" asp-for="DiscountAmount" id="discountAmountInput" />
                    <input type="hidden" asp-for="PaymentMethod" value="COD" />

                    <div class="d-flex justify-content-between mb-3">
                        <span>Tổng sản phẩm</span>
                        <span>@Model.CartItems.Sum(x => x.Quantity)</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span>Tạm tính</span>
                        <span>@String.Format(new CultureInfo("vi-VN"), "{0:N0} đ", Model.SubTotal)</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span>Giảm giá</span>
                        <span class="text-success" id="discountAmountText">
                            - @String.Format(new CultureInfo("vi-VN"), "{0:N0} đ", Model.DiscountAmount)
                        </span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Phương thức thanh toán</label>
                        <input class="form-control" value="Thanh toán khi nhận hàng (COD)" disabled />
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold">Tổng thanh toán</span>
                        <span class="fw-bold text-danger fs-4" id="finalTotalText">
                            @String.Format(new CultureInfo("vi-VN"), "{0:N0} đ", Model.FinalTotal)
                        </span>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary btn-soft flex-fill">
                            Quay lại giỏ
                        </a>
                        <button type="submit" class="btn btn-success btn-soft flex-fill">
                            Đặt hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function toggleAddressBox() {
            const useNew = document.getElementById("useNewAddress");
            const box = document.getElementById("newAddressBox");
            const savedRadios = document.querySelectorAll(".saved-address-radio");

            if (useNew && box) {
                const isNew = useNew.checked;
                box.style.display = isNew ? "block" : "none";

                savedRadios.forEach(r => {
                    r.disabled = isNew;
                    if (isNew) r.checked = false;
                });
            }
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('vi-VN').format(value) + ' đ';
        }

        function applyCoupon() {
            const code = document.getElementById("couponCodeInput").value;
            const message = document.getElementById("couponMessage");

            fetch('/Order/ApplyCoupon', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'code=' + encodeURIComponent(code)
            })
            .then(response => response.json())
            .then(data => {
                if (!data.success) {
                    message.className = "small mt-2 text-danger";
                    message.innerText = data.message;

                    document.getElementById("discountAmountText").innerText = "- 0 đ";
                    document.getElementById("finalTotalText").innerText = formatCurrency(@Model.SubTotal);
                    document.getElementById("discountAmountInput").value = 0;
                } else {
                    message.className = "small mt-2 text-success";
                    message.innerText = data.message;

                    document.getElementById("discountAmountText").innerText =
                        "- " + formatCurrency(data.discountAmount);

                    document.getElementById("finalTotalText").innerText =
                        formatCurrency(data.finalTotal);

                    document.getElementById("discountAmountInput").value = data.discountAmount;
                }
            })
            .catch(() => {
                message.className = "small mt-2 text-danger";
                message.innerText = "Không thể áp dụng mã giảm giá lúc này.";
            });
        }

        document.addEventListener("DOMContentLoaded", function () {
            const radios = document.querySelectorAll("input[name='UseNewAddress']");
            radios.forEach(r => r.addEventListener("change", toggleAddressBox));
            toggleAddressBox();
        });
    </script>
}