@model IEnumerable<Shopping.Models.Category>

<div class="category-sidebar">
    <div class="category-header">
        <div class="category-header-icon">
            <i class="fas fa-layer-group"></i>
        </div>
        <div>
            <h5 class="mb-0 fw-bold">Danh mục sản phẩm</h5>
            <small>Khám phá theo nhóm hàng</small>
        </div>
    </div>

    <div class="category-list">
        <a asp-controller="Product"
           asp-action="ListPublic"
           asp-route-categoryId=""
           class="category-link category-all">
            <div class="category-left">
                <span class="category-icon">
                    <i class="fas fa-store"></i>
                </span>
                <span>Tất cả sản phẩm</span>
            </div>
            <i class="fas fa-angle-right"></i>
        </a>

        @foreach (var item in Model)
        {
            <a asp-controller="Product"
               asp-action="ListPublic"
               asp-route-categoryId="@item.CategoryId"
               class="category-link">
                <div class="category-left">
                    <span class="category-icon">
                        <i class="fas fa-chevron-right"></i>
                    </span>
                    <span>@item.CategoryName</span>
                </div>
                <i class="fas fa-angle-right category-arrow"></i>
            </a>
        }
    </div>

    <div class="category-footer">
        <i class="fas fa-fire text-warning me-2"></i>
        <span>Cập nhật sản phẩm mới mỗi ngày</span>
    </div>
</div>

<style>
    .category-sidebar {
        display: flex;
        flex-direction: column;
        height: 100%;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .category-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 20px 20px 16px 20px;
        border-bottom: 1px solid #edf2f7;
        background: linear-gradient(135deg, #eff6ff, #f8fbff);
    }

        .category-header h5 {
            color: #0f172a;
            font-size: 18px;
        }

        .category-header small {
            color: #64748b;
            font-size: 13px;
        }

    .category-header-icon {
        width: 46px;
        height: 46px;
        min-width: 46px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #2563eb, #60a5fa);
        color: white;
        font-size: 18px;
        box-shadow: 0 10px 24px rgba(37, 99, 235, 0.25);
    }

    .category-list {
        padding: 14px 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .category-link {
        display: flex;
        justify-content: space-between;
        align-items: center;
        text-decoration: none;
        color: #1e293b;
        padding: 12px 14px;
        border-radius: 16px;
        border: 1px solid transparent;
        background: rgba(255,255,255,0.85);
        transition: all 0.25s ease;
        font-weight: 600;
    }

        .category-link:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
            color: #2563eb;
            transform: translateX(4px);
            box-shadow: 0 10px 20px rgba(37, 99, 235, 0.08);
        }

    .category-all {
        background: linear-gradient(135deg, #2563eb, #3b82f6);
        color: white !important;
        box-shadow: 0 12px 24px rgba(37, 99, 235, 0.18);
    }

        .category-all:hover {
            background: linear-gradient(135deg, #1d4ed8, #2563eb);
            color: white !important;
            border-color: transparent;
        }

    .category-left {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .category-icon {
        width: 34px;
        height: 34px;
        min-width: 34px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f1f5f9;
        color: #2563eb;
        font-size: 13px;
        transition: all 0.25s ease;
    }

    .category-all .category-icon {
        background: rgba(255,255,255,0.18);
        color: white;
    }

    .category-link:hover .category-icon {
        background: #dbeafe;
        color: #2563eb;
    }

    .category-arrow {
        color: #94a3b8;
        transition: all 0.25s ease;
    }

    .category-link:hover .category-arrow {
        color: #2563eb;
        transform: translateX(3px);
    }

    .category-all .category-arrow {
        color: rgba(255,255,255,0.9);
    }

    .category-footer {
        margin-top: auto;
        padding: 14px 16px 18px 16px;
        border-top: 1px solid #edf2f7;
        color: #475569;
        font-size: 13px;
        background: rgba(255,255,255,0.75);
    }
</style>