@model IEnumerable<Shopping.Models.Product>
@using System.Linq
@using System.Globalization
@using Shopping.Models

@{
    ViewData["Title"] = "Trang chủ";

    var products = Model?.ToList() ?? new List<Shopping.Models.Product>();
    var groupedProducts = products
        .Select((value, index) => new { value, index })
        .GroupBy(x => x.index / 4)
        .Select(g => g.Select(x => x.value).ToList())
        .ToList();

    var hotCoupons = ViewBag.HotCoupons as List<Coupon> ?? new List<Coupon>();
    var shoeProducts = ViewBag.ShoeProducts as List<Product> ?? new List<Product>();
    var gymProducts = ViewBag.GymProducts as List<Product> ?? new List<Product>();
    var ballProducts = ViewBag.BallProducts as List<Product> ?? new List<Product>();
}

<style>
    .homepage-wrap {
        padding-bottom: 56px;
        background: radial-gradient(circle at top left, rgba(59,130,246,.05), transparent 20%), radial-gradient(circle at bottom right, rgba(16,185,129,.04), transparent 16%);
    }

    .top-strip {
        background: #0f172a;
        color: rgba(255,255,255,.84);
        font-size: 14px;
    }

        .top-strip .item {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 0;
            font-weight: 500;
        }

        .top-strip .highlight {
            color: #facc15;
            font-weight: 700;
        }

    .hero-section {
        padding: 24px 0 18px;
    }

    .hero-slider-box {
        position: relative;
        overflow: hidden;
        border-radius: 34px;
        box-shadow: 0 30px 70px rgba(15,23,42,0.18);
    }

    .hero-slide {
        background: radial-gradient(circle at top right, rgba(59,130,246,.28), transparent 25%), radial-gradient(circle at bottom left, rgba(16,185,129,.15), transparent 18%), linear-gradient(135deg, #0f172a 0%, #1e3a8a 55%, #2563eb 100%);
        color: white;
        min-height: 560px;
    }

        .hero-slide.alt-slide-2 {
            background: radial-gradient(circle at top right, rgba(249,115,22,.20), transparent 24%), radial-gradient(circle at bottom left, rgba(234,179,8,.12), transparent 18%), linear-gradient(135deg, #111827 0%, #1f2937 50%, #ea580c 100%);
        }

        .hero-slide.alt-slide-3 {
            background: radial-gradient(circle at top right, rgba(16,185,129,.24), transparent 24%), radial-gradient(circle at bottom left, rgba(45,212,191,.14), transparent 18%), linear-gradient(135deg, #052e16 0%, #064e3b 50%, #0f766e 100%);
        }

    .hero-content {
        padding: 66px 52px 46px;
    }

    .hero-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.14);
        color: #fff;
        padding: 9px 16px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 14px;
        margin-bottom: 22px;
        backdrop-filter: blur(8px);
    }

    .hero-title {
        font-size: 3.1rem;
        font-weight: 800;
        line-height: 1.06;
        letter-spacing: -1.2px;
        margin-bottom: 18px;
    }

    .hero-desc {
        color: rgba(255,255,255,0.82);
        font-size: 1.05rem;
        max-width: 560px;
        margin-bottom: 28px;
    }

    .hero-actions .btn {
        border-radius: 18px;
        font-weight: 700;
        padding: 14px 24px;
    }

    .hero-metric {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 22px;
        padding: 18px;
        backdrop-filter: blur(10px);
        text-align: center;
        height: 100%;
    }

        .hero-metric h4 {
            font-weight: 800;
            margin-bottom: 4px;
        }

    .hero-visual {
        padding: 34px 34px 34px 0;
    }

    .hero-image {
        width: 100%;
        min-height: 430px;
        max-height: 470px;
        object-fit: cover;
        border-radius: 28px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.24);
        background: #fff;
    }

    .hero-search-card {
        margin-top: -42px;
        position: relative;
        z-index: 20;
    }

    .search-panel {
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(226,232,240,0.95);
        border-radius: 26px;
        box-shadow: 0 20px 45px rgba(15,23,42,0.10);
        padding: 20px;
        backdrop-filter: blur(10px);
    }

        .search-panel .form-control,
        .search-panel .form-select {
            min-height: 54px;
            border-radius: 16px;
            border: 1px solid #dbe2ea;
        }

        .search-panel .btn {
            min-height: 54px;
            border-radius: 16px;
            font-weight: 700;
        }

    .section-block {
        padding: 38px 0;
    }

    .section-head {
        margin-bottom: 24px;
    }

    .section-title {
        font-weight: 800;
        letter-spacing: -0.6px;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .section-subtitle {
        color: #64748b;
        margin-bottom: 0;
    }

    .feature-card,
    .coupon-card,
    .promo-card,
    .product-card,
    .category-card,
    .review-card,
    .brand-card,
    .flash-card {
        background: rgba(255,255,255,0.90);
        border: 1px solid rgba(226,232,240,0.95);
        border-radius: 26px;
        box-shadow: 0 14px 36px rgba(15,23,42,0.06);
        backdrop-filter: blur(10px);
    }

    .feature-card,
    .review-card,
    .flash-card {
        padding: 28px;
        height: 100%;
        transition: .28s;
    }

        .feature-card:hover,
        .category-card:hover,
        .product-card:hover,
        .review-card:hover,
        .coupon-card:hover,
        .brand-card:hover,
        .flash-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 22px 48px rgba(15,23,42,0.10);
        }

    .feature-icon,
    .category-icon,
    .brand-icon {
        width: 66px;
        height: 66px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #dbeafe, #eff6ff);
        color: #2563eb;
        font-size: 24px;
        margin-bottom: 18px;
    }

    .category-card {
        padding: 24px;
        display: block;
        text-decoration: none;
        color: inherit;
        transition: .28s;
        height: 100%;
    }

        .category-card:hover {
            color: inherit;
        }

    .coupon-card {
        padding: 24px;
        height: 100%;
        position: relative;
        overflow: hidden;
    }

        .coupon-card::after {
            content: "";
            position: absolute;
            top: -30px;
            right: -30px;
            width: 110px;
            height: 110px;
            border-radius: 50%;
            background: rgba(37,99,235,0.06);
        }

    .coupon-code {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: #eff6ff;
        color: #2563eb;
        font-weight: 800;
        letter-spacing: .5px;
        margin-bottom: 14px;
    }

    .coupon-value {
        font-size: 1.55rem;
        font-weight: 800;
        color: #ef4444;
        margin-bottom: 10px;
    }

    .countdown-text {
        color: #ef4444;
        font-weight: 700;
        font-size: 14px;
    }

    .brand-card {
        padding: 22px;
        text-align: center;
        height: 100%;
        transition: .28s;
    }

    .brand-name {
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 6px;
    }

    .brand-desc {
        color: #64748b;
        font-size: 14px;
        margin-bottom: 0;
    }

    .flash-card {
        background: radial-gradient(circle at top right, rgba(239,68,68,.12), transparent 22%), linear-gradient(135deg, rgba(255,255,255,.96), rgba(248,250,252,.92));
    }

    .flash-countdown {
        display: inline-flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .flash-time-box {
        min-width: 78px;
        text-align: center;
        border-radius: 16px;
        background: #0f172a;
        color: #fff;
        padding: 14px 10px;
    }

        .flash-time-box strong {
            display: block;
            font-size: 1.25rem;
            font-weight: 800;
        }

    .featured-slider-wrap {
        position: relative;
        padding: 0 34px;
    }

    .slider-btn {
        width: 54px;
        height: 54px;
        border: none;
        border-radius: 50%;
        background: rgba(255,255,255,0.95);
        box-shadow: 0 12px 28px rgba(15,23,42,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        transition: 0.25s;
        color: #0f172a;
    }

        .slider-btn:hover {
            background: #2563eb;
            color: white;
        }

        .slider-btn.prev-btn {
            left: -4px;
        }

        .slider-btn.next-btn {
            right: -4px;
        }

    .product-card {
        overflow: hidden;
        transition: .28s;
        height: 100%;
    }

    .product-thumb {
        height: 230px;
        background: linear-gradient(180deg, #f8fafc, #eef2ff);
        overflow: hidden;
        position: relative;
    }

        .product-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .35s;
        }

    .product-card:hover .product-thumb img {
        transform: scale(1.06);
    }

    .product-badge {
        position: absolute;
        top: 14px;
        right: 14px;
        background: rgba(255,255,255,0.94);
        color: #2563eb;
        font-size: 12px;
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 999px;
        box-shadow: 0 10px 20px rgba(15,23,42,0.08);
        z-index: 2;
    }

    .out-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        background: #ef4444;
        color: white;
        font-size: 12px;
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 999px;
        z-index: 2;
    }

    .quick-action {
        position: absolute;
        left: 14px;
        right: 14px;
        bottom: -60px;
        transition: .3s;
    }

    .product-card:hover .quick-action {
        bottom: 14px;
    }

    .price-text {
        font-size: 1.28rem;
        font-weight: 800;
        color: #ef4444;
    }

    .stock-text {
        font-size: 12px;
        color: #64748b;
    }

    .product-name {
        min-height: 46px;
        line-height: 1.4;
    }

    .soft-btn {
        border-radius: 16px;
        font-weight: 700;
    }

    .promo-card {
        padding: 42px;
        background: radial-gradient(circle at right top, rgba(37,99,235,.25), transparent 25%), linear-gradient(135deg, #111827, #0f172a);
        color: white;
        overflow: hidden;
        position: relative;
    }

        .promo-card p {
            color: rgba(255,255,255,.78);
        }

    .review-stars {
        color: #f59e0b;
        margin-bottom: 12px;
    }

    .empty-box {
        border: 2px dashed #cbd5e1;
        border-radius: 26px;
        padding: 60px 20px;
        background: rgba(255,255,255,0.68);
        text-align: center;
    }

    @@media (max-width: 991px) {
        .hero-content {
            padding: 42px 28px;
        }

        .hero-title {
            font-size: 2.2rem;
        }

        .hero-visual {
            padding: 0 28px 28px;
        }

        .featured-slider-wrap {
            padding: 0 10px;
        }

        .slider-btn {
            width: 44px;
            height: 44px;
        }

            .slider-btn.prev-btn {
                left: -10px;
            }

            .slider-btn.next-btn {
                right: -10px;
            }

        .hero-search-card {
            margin-top: 18px;
        }
    }

    @@media (max-width: 767px) {
        .hero-title {
            font-size: 1.85rem;
        }

        .slider-btn {
            display: none;
        }
    }
</style>

<div class="homepage-wrap">

    @* NOTE: Top bar giúp homepage có cảm giác đầy đủ và chuyên nghiệp hơn *@
    <div class="top-strip">
        <div class="container">
            <div class="row g-2 align-items-center">
                <div class="col-lg-4">
                    <div class="item">
                        <i class="fas fa-truck"></i>
                        Giao nhanh toàn quốc
                    </div>
                </div>
                <div class="col-lg-4 text-lg-center">
                    <div class="item">
                        <i class="fas fa-money-bill-wave"></i>
                        Chỉ thanh toán <span class="highlight">COD</span>
                    </div>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="item">
                        <i class="fas fa-ticket-alt"></i>
                        Voucher đang hoạt động:
                        <span class="highlight">@(hotCoupons.Any() ? hotCoupons.Count.ToString() : "0") mã</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <section class="hero-section">
        <div class="container">
            <div class="hero-slider-box">
                <div id="homeHeroCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <div class="hero-slide">
                                <div class="row align-items-center g-0">
                                    <div class="col-lg-7">
                                        <div class="hero-content">
                                            <div class="hero-chip">
                                                <i class="fas fa-bolt text-warning"></i>
                                                Cửa hàng đồ thể thao chính hãng
                                            </div>

                                            <h1 class="hero-title">
                                                Trang bị thể thao chuẩn chất lượng, sẵn sàng cho mọi trận đấu
                                            </h1>

                                            <p class="hero-desc">
                                                Khám phá giày thể thao, bóng, phụ kiện tập luyện và dụng cụ gym tại VitaSport với giá tốt, giao nhanh và thanh toán COD tiện lợi.
                                            </p>

                                            <div class="d-flex flex-wrap gap-3 hero-actions mb-4">
                                                <a asp-controller="Product" asp-action="ListPublic" class="btn btn-primary shadow">
                                                    Mua ngay
                                                </a>

                                                <a href="#featured-products" class="btn btn-light text-dark">
                                                    Xem sản phẩm nổi bật
                                                </a>
                                            </div>

                                            <div class="row g-3 mt-1">
                                                <div class="col-4">
                                                    <div class="hero-metric">
                                                        <h4>@products.Count+</h4>
                                                        <small class="text-white-50">Sản phẩm nổi bật</small>
                                                    </div>
                                                </div>
                                                <div class="col-4">
                                                    <div class="hero-metric">
                                                        <h4>24/7</h4>
                                                        <small class="text-white-50">Hỗ trợ</small>
                                                    </div>
                                                </div>
                                                <div class="col-4">
                                                    <div class="hero-metric">
                                                        <h4>COD</h4>
                                                        <small class="text-white-50">Thanh toán</small>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-lg-5">
                                        <div class="hero-visual">
                                            <img class="hero-image"
                                                 src="@(products.FirstOrDefault()?.ImageUrl ?? "/images/products/no-image.png")"
                                                 alt="VitaSport Hero"
                                                 onerror="this.onerror=null; this.src='/images/products/no-image.png';" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="carousel-item">
                            <div class="hero-slide alt-slide-2">
                                <div class="row align-items-center g-0">
                                    <div class="col-lg-7">
                                        <div class="hero-content">
                                            <div class="hero-chip">
                                                <i class="fas fa-shoe-prints text-warning"></i>
                                                Bộ sưu tập giày & outfit mới
                                            </div>

                                            <h2 class="hero-title">
                                                Chạy bộ, tập gym hay thi đấu đều có lựa chọn phù hợp
                                            </h2>

                                            <p class="hero-desc">
                                                Sản phẩm được chọn lọc theo nhu cầu thực tế, dễ tìm kiếm, dễ đặt hàng và tối ưu trải nghiệm mua sắm trực tuyến.
                                            </p>

                                            <div class="d-flex flex-wrap gap-3 hero-actions mb-4">
                                                <a asp-controller="Product" asp-action="ListPublic" asp-route-categoryId="4" class="btn btn-warning text-dark shadow">
                                                    Xem giày thể thao
                                                </a>

                                                <a asp-controller="Product" asp-action="ListPublic" asp-route-categoryId="5" class="btn btn-light text-dark">
                                                    Xem quần áo
                                                </a>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-lg-5">
                                        <div class="hero-visual">
                                            <img class="hero-image"
                                                 src="@(products.Skip(1).FirstOrDefault()?.ImageUrl ?? "/images/products/no-image.png")"
                                                 alt="Giày thể thao"
                                                 onerror="this.onerror=null; this.src='/images/products/no-image.png';" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="carousel-item">
                            <div class="hero-slide alt-slide-3">
                                <div class="row align-items-center g-0">
                                    <div class="col-lg-7">
                                        <div class="hero-content">
                                            <div class="hero-chip">
                                                <i class="fas fa-dumbbell text-warning"></i>
                                                Dụng cụ tập luyện & phụ kiện
                                            </div>

                                            <h2 class="hero-title">
                                                Nâng cấp buổi tập mỗi ngày bằng thiết bị phù hợp
                                            </h2>

                                            <p class="hero-desc">
                                                Từ dụng cụ gym đến phụ kiện hỗ trợ, VitaSport mang đến giải pháp mua sắm thể thao đồng bộ, đẹp mắt và dễ sử dụng.
                                            </p>

                                            <div class="d-flex flex-wrap gap-3 hero-actions mb-4">
                                                <a asp-controller="Product" asp-action="ListPublic" asp-route-categoryId="7" class="btn btn-success shadow">
                                                    Dụng cụ gym
                                                </a>

                                                <a asp-controller="Product" asp-action="ListPublic" asp-route-categoryId="6" class="btn btn-light text-dark">
                                                    Phụ kiện tập luyện
                                                </a>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-lg-5">
                                        <div class="hero-visual">
                                            <img class="hero-image"
                                                 src="@(products.Skip(2).FirstOrDefault()?.ImageUrl ?? "/images/products/no-image.png")"
                                                 alt="Dụng cụ gym"
                                                 onerror="this.onerror=null; this.src='/images/products/no-image.png';" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>

                    <button class="carousel-control-next" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                </div>
            </div>
        </div>
    </section>

    @* NOTE: Search panel dùng form GET để chuyển dữ liệu thật sang trang Product/ListPublic *@
    <section class="hero-search-card">
        <div class="container">
            <div class="search-panel">
                <form asp-controller="Product" asp-action="ListPublic" method="get">
                    <div class="row g-3 align-items-center">
                        <div class="col-lg-5">
                            <input type="text" name="query" class="form-control" placeholder="Tìm kiếm giày, bóng, phụ kiện, dụng cụ gym..." />
                        </div>
                        <div class="col-lg-3">
                            <select name="categoryId" class="form-select">
                                <option value="">Tất cả danh mục</option>
                                <option value="4">Giày thể thao</option>
                                <option value="5">Quần áo thể thao</option>
                                <option value="6">Phụ kiện tập luyện</option>
                                <option value="7">Dụng cụ gym</option>
                                <option value="8">Bóng thể thao</option>
                            </select>
                        </div>
                        <div class="col-lg-2">
                            <select name="sortOrder" class="form-select">
                                <option value="">Sắp xếp nổi bật</option>
                                <option value="price_asc">Giá tăng dần</option>
                                <option value="price_desc">Giá giảm dần</option>
                                <option value="name_asc">Tên A-Z</option>
                                <option value="name_desc">Tên Z-A</option>
                            </select>
                        </div>
                        <div class="col-lg-2">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-search me-2"></i>Tìm ngay
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <section class="section-block">
        <div class="container">
            <div class="text-center section-head">
                <h2 class="section-title">Danh mục mua sắm nổi bật</h2>
                <p class="section-subtitle">Tìm nhanh nhóm sản phẩm phù hợp với nhu cầu luyện tập của bạn</p>
            </div>

            <div class="row g-4">
                <div class="col-6 col-md-4 col-lg-2">
                    <a asp-controller="Product" asp-action="ListPublic" asp-route-categoryId="4" class="category-card">
                        <div class="category-icon">
                            <i class="fas fa-shoe-prints"></i>
                        </div>
                        <h6 class="fw-bold mb-1">Giày thể thao</h6>
                        <small class="text-muted">Êm, bền, đẹp</small>
                    </a>
                </div>

                <div class="col-6 col-md-4 col-lg-2">
                    <a asp-controller="Product" asp-action="ListPublic" asp-route-categoryId="5" class="category-card">
                        <div class="category-icon">
                            <i class="fas fa-tshirt"></i>
                        </div>
                        <h6 class="fw-bold mb-1">Quần áo</h6>
                        <small class="text-muted">Thoải mái vận động</small>
                    </a>
                </div>

